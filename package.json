{
  "name": "3dfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "optimize-images": "squoosh-cli --webp '{quality:90}' 'src/assets/**/*.{png,jpg,jpeg}'",
    "optimize:hero": "squoosh-cli --resize '{width:1200}' --webp '{quality:80}' src/assets/hero-image.png",
    "optimize:projects": "squoosh-cli --resize '{width:800}' --webp '{quality:85}' src/assets/projects/*.png",
    "optimize:all": "npm run optimize-images && npm run optimize:hero && npm run optimize:projects"
  },
  "dependencies": {
    "@emailjs/browser": "^3.10.0",
    "@react-three/drei": "^9.56.24",
    "@react-three/fiber": "^8.11.1",
    "framer-motion": "^9.0.7",
    "maath": "^0.5.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.4.0",
    "react-parallax-tilt": "^1.7.269",
    "react-router-dom": "^6.8.1",
    "react-vertical-timeline-component": "^3.6.0",
    "three": "^0.149.0"
  },
  "devDependencies": {
    "@squoosh/cli": "^0.7.1",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.13",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.6",
    "vite": "^4.1.0"
  }
}